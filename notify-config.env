# Claude Code idle notification config
# Fill these in to enable Telegram escalation after 5 minutes of idle.
#
# 1. Message @BotFather on Telegram, send /newbot, follow prompts
# 2. Copy the bot token here
# 3. Message your new bot, then visit:
#    https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#    to find your chat_id
#
# TELEGRAM_BOT_TOKEN="123456:ABC-DEF..."
# TELEGRAM_CHAT_ID="your_chat_id"
